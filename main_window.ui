               <item>
                <widget class="QLabel" name="label_cover_letter_system_prompt">
                 <property name="text">
                  <string>COVER_LETTER_SYSTEM_PROMPT</string>
                 </property>
                </widget>
               </item>
               <item>
                <widget class="QPlainTextEdit" name="text_cover_letter_system_prompt">
                 <property name="plainText">
                  <string>You write concise, specific, professional cover letters.
Use only the provided materials.
Do not invent experience.
Do not mention missing information.
Output only the final cover letter text.</string>
                 </property>
                </widget>
               </item>
               <item>
